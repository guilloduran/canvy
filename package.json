{
  "name": "canvy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:sketch": "canvas-sketch-cli sketches/sketch-06.js --build --output=public/letry --stream",
    "watch:sketch": "canvas-sketch-cli sketches/sketch-06.js --output=public/letry",
    "build:all": "npm run build:sketch && next build",
    "dev:sketch": "concurrently \"npm run dev\" \"npm run watch:sketch\""
  },
  "dependencies": {
    "canvas-sketch": "^0.7.7",
    "canvas-sketch-cli": "^1.11.21",
    "canvas-sketch-util": "^1.10.0",
    "next": "14.1.0",
    "react": "^18",
    "react-dom": "^18",
    "tweakpane": "^3.1.9"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^8.2.2",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
